{
  "name": "@neoskop/migrateus",
  "version": "2.6.2",
  "description": "Migrations for Directus",
  "author": "Arne Diekmann <diekmann@neoskop.de>",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "migrateus": "dist/src/main.js"
  },
  "repository": "github:neoskop/migrateus",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "nest build && chmod +x dist/src/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:debug": "node --inspect-brk --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json",
    "watch": "nodemon --ext ts --watch 'src/**/*.ts' --exec 'npm run build'",
    "gv": "genversion --esm src/version.ts",
    "release": "echo 'Use the Release GitHub Action instead' && exit 1",
    "jscpd": "jscpd --pattern=**/*.ts src/",
    "update-changelog": "git-cliff -o --tag $version"
  },
  "dependencies": {
    "@directus/sdk": "22.0.0",
    "@inquirer/confirm": "6.1.1",
    "@inquirer/core": "11.2.1",
    "@inquirer/expand": "5.1.1",
    "@inquirer/figures": "2.0.7",
    "@inquirer/password": "5.1.1",
    "@inquirer/select": "5.2.1",
    "@inquirer/type": "4.0.7",
    "@nestjs/common": "11.1.27",
    "@nestjs/core": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "argon2": "0.44.0",
    "chalk": "5.6.2",
    "cli-highlight": "2.1.11",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "file-type": "22.0.1",
    "glob": "13.0.6",
    "js-yaml": "4.2.0",
    "mime-types": "3.0.2",
    "nanoid": "5.1.16",
    "nest-commander": "3.20.1",
    "ora": "9.4.1",
    "p-limit": "7.3.0",
    "portfinder": "1.0.38",
    "pretty-bytes": "7.1.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "semver": "7.8.5",
    "shelljs": "0.10.0",
    "tmp": "0.2.6",
    "uuid": "14.0.1",
    "which": "7.0.0"
  },
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@types/cli-progress": "3.11.6",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.2",
    "@types/semver": "7.7.1",
    "@types/shelljs": "0.10.0",
    "@types/supertest": "7.2.0",
    "@types/tmp": "0.2.6",
    "@types/which": "3.0.4",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "genversion": "3.2.0",
    "git-cliff": "2.13.1",
    "jest": "30.4.2",
    "jscpd": "5.0.11",
    "nest-commander-schematics": "3.2.0",
    "nodemon": "3.1.14",
    "prettier": "3.8.4",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageThreshold": {
      "src/sql/sql-escape.ts": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "testEnvironment": "node"
  }
}
