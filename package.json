{
  "name": "migrateus",
  "version": "0.0.1",
  "description": "Migrations for Directus",
  "author": "Arne Diekmann <diekmann@neoskop.de>",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "migrateus": "dist/main.js"
  },
  "scripts": {
    "build": "nest build && chmod +x dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "watch": "nodemon --ext ts --watch 'src/**/*.ts' --exec 'npm run build'",
    "gv": "genversion --esm src/version.ts",
    "release": "npm run gv && npm run build && npm publish"
  },
  "dependencies": {
    "@1password/op-js": "0.1.13",
    "@directus/sdk": "16.1.1",
    "@kubernetes/client-node": "0.21.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "argon2": "0.40.3",
    "chalk": "5.3.0",
    "cli-highlight": "2.1.11",
    "cli-progress": "3.12.0",
    "dotenv": "16.4.5",
    "file-type": "19.0.0",
    "glob": "10.4.2",
    "js-yaml": "4.1.0",
    "mime-types": "2.1.35",
    "nanoid": "5.0.7",
    "nest-commander": "3.14.0",
    "nest-winston": "1.10.0",
    "node-which": "1.0.0",
    "p-limit": "6.0.0",
    "portfinder": "1.0.32",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "shelljs": "0.8.5",
    "tmp": "0.2.3",
    "uuid": "10.0.0",
    "winston": "3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.2",
    "@nestjs/testing": "^10.3.10",
    "@types/cli-progress": "3.11.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/shelljs": "0.8.15",
    "@types/supertest": "^6.0.2",
    "@types/tmp": "0.2.6",
    "@types/uuid": "10.0.0",
    "@types/which": "3.0.4",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "genversion": "3.2.0",
    "jest": "^29.7.0",
    "nest-commander-schematics": "3.0.0",
    "nodemon": "3.1.4",
    "prettier": "^3.3.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}