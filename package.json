{
  "name": "@neoskop/migrateus",
  "version": "1.2.1",
  "description": "Migrations for Directus",
  "author": "Arne Diekmann <diekmann@neoskop.de>",
  "publishConfig": {
    "access": "restricted"
  },
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "migrateus": "dist/main.js"
  },
  "scripts": {
    "build": "nest build && chmod +x dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "watch": "nodemon --ext ts --watch 'src/**/*.ts' --exec 'npm run build'",
    "gv": "genversion --esm src/version.ts",
    "release": "npm run gv && npm run build && npm publish",
    "jscpd": "jscpd --pattern=**/*.ts src/",
    "update-changelog": "git-cliff -o --tag $version"
  },
  "dependencies": {
    "@directus/sdk": "17.0.2",
    "@inquirer/confirm": "4.0.1",
    "@inquirer/expand": "3.0.1",
    "@inquirer/password": "3.0.1",
    "@inquirer/select": "3.0.1",
    "@nestjs/common": "^10.4.1",
    "@nestjs/core": "^10.4.1",
    "@nestjs/platform-express": "^10.4.1",
    "argon2": "0.41.1",
    "chalk": "5.3.0",
    "cli-highlight": "2.1.11",
    "date-fns": "4.1.0",
    "dotenv": "16.4.5",
    "file-type": "19.6.0",
    "glob": "11.0.0",
    "js-yaml": "4.1.0",
    "mime-types": "2.1.35",
    "nanoid": "5.0.8",
    "nest-commander": "3.15.0",
    "nest-winston": "1.10.0",
    "ora": "8.1.0",
    "p-limit": "6.1.0",
    "portfinder": "1.0.32",
    "pretty-bytes": "6.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "semver": "7.6.3",
    "shelljs": "0.8.5",
    "tmp": "0.2.3",
    "uuid": "10.0.0",
    "which": "4.0.0",
    "winston": "3.15.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.1",
    "@types/cli-progress": "3.11.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^22.5.4",
    "@types/semver": "7.5.8",
    "@types/shelljs": "0.8.15",
    "@types/supertest": "^6.0.2",
    "@types/tmp": "0.2.6",
    "@types/uuid": "10.0.0",
    "@types/which": "3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.5.0",
    "@typescript-eslint/parser": "^8.5.0",
    "eslint": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "genversion": "3.2.0",
    "git-cliff": "2.6.1",
    "jest": "^29.7.0",
    "jscpd": "4.0.5",
    "nest-commander-schematics": "3.0.2",
    "nodemon": "3.1.7",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
