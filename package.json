{
  "name": "@neoskop/migrateus",
  "version": "2.5.1",
  "description": "Migrations for Directus",
  "author": "Arne Diekmann <diekmann@neoskop.de>",
  "publishConfig": {
    "access": "restricted"
  },
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "migrateus": "dist/main.js"
  },
  "scripts": {
    "build": "nest build && chmod +x dist/main.js",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "watch": "nodemon --ext ts --watch 'src/**/*.ts' --exec 'npm run build'",
    "gv": "genversion --esm src/version.ts",
    "release": "npm run gv && npm run build && npm publish",
    "jscpd": "jscpd --pattern=**/*.ts src/",
    "update-changelog": "git-cliff -o --tag $version"
  },
  "dependencies": {
    "@directus/sdk": "21.1.0",
    "@inquirer/confirm": "6.0.7",
    "@inquirer/core": "11.1.4",
    "@inquirer/expand": "5.0.7",
    "@inquirer/figures": "2.0.3",
    "@inquirer/password": "5.0.7",
    "@inquirer/select": "5.0.7",
    "@inquirer/type": "4.0.3",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "argon2": "0.44.0",
    "chalk": "5.6.2",
    "cli-highlight": "2.1.11",
    "date-fns": "4.1.0",
    "dotenv": "17.3.1",
    "file-type": "21.3.0",
    "glob": "13.0.6",
    "js-yaml": "4.1.1",
    "mime-types": "3.0.2",
    "nanoid": "5.1.6",
    "nest-commander": "3.20.1",
    "nest-winston": "1.10.2",
    "ora": "9.3.0",
    "p-limit": "7.3.0",
    "portfinder": "1.0.38",
    "pretty-bytes": "7.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "7.7.4",
    "shelljs": "0.10.0",
    "tmp": "0.2.5",
    "uuid": "13.0.0",
    "which": "6.0.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.12",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/cli-progress": "3.11.6",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "^24.10.1",
    "@types/semver": "7.7.1",
    "@types/shelljs": "0.10.0",
    "@types/supertest": "^6.0.3",
    "@types/tmp": "0.2.6",
    "@types/which": "3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "genversion": "3.2.0",
    "git-cliff": "2.12.0",
    "jest": "^30.2.0",
    "jscpd": "4.0.8",
    "nest-commander-schematics": "3.2.0",
    "nodemon": "3.1.14",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
